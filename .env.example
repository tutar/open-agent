# Core provider/runtime
OPENAGENT_PROVIDER=openai
OPENAGENT_BASE_URL=http://127.0.0.1:8001
# Set this to a model ID advertised by GET ${OPENAGENT_BASE_URL}/v1/models.
OPENAGENT_MODEL=unsloth/Qwen3.5-9B-GGUF
OPENAGENT_API_KEY=
OPENAGENT_WORKSPACE_ROOT=$PWD

# Host/runtime storage
OPENAGENT_HOST_ROOT=.openagent/host
OPENAGENT_DATA_ROOT=.openagent/data
OPENAGENT_MODEL_IO_ROOT=.openagent/data/model-io
OPENAGENT_SESSION_ROOT=.openagent/host/sessions
OPENAGENT_BINDING_ROOT=.openagent/host/bindings
OPENAGENT_TERMINAL_HOST=127.0.0.1
OPENAGENT_TERMINAL_PORT=8765

# Observability
OPENAGENT_OBSERVABILITY_STDOUT=true

# Feishu channel
OPENAGENT_FEISHU_APP_ID=cli_xxx
OPENAGENT_FEISHU_APP_SECRET=xxx
OPENAGENT_FEISHU_LOCK_ROOT=/tmp/openagent-feishu-locks
OPENAGENT_FEISHU_GROUP_AT_ONLY=true
# If unset, Feishu defaults to ${OPENAGENT_SESSION_ROOT}/cards under the Feishu session root.
# Recommended explicit value when running Feishu standalone:
OPENAGENT_FEISHU_CARD_STATE_ROOT=.openagent/feishu/sessions/cards

# WeChat private chat channel
OPENAGENT_WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
OPENAGENT_WECHAT_CRED_PATH=.openagent/wechat/credentials.json
OPENAGENT_WECHAT_ALLOWED_SENDERS=

# WeCom private chat channel
OPENAGENT_WECOM_BOT_ID=
OPENAGENT_WECOM_SECRET=
OPENAGENT_WECOM_WS_URL=wss://openws.work.weixin.qq.com
OPENAGENT_WECOM_ALLOWED_USERS=
OPENAGENT_WECOM_PING_INTERVAL_SECONDS=30
OPENAGENT_WECOM_DEBUG=false

# Web fetch/search backends
OPENAGENT_WEBFETCH_BACKEND=firecrawl
OPENAGENT_WEBSEARCH_BACKEND=firecrawl
OPENAGENT_FIRECRAWL_BASE_URL=http://127.0.0.1:3002
OPENAGENT_FIRECRAWL_API_KEY=

# Tavily search backend
# Set OPENAGENT_WEBSEARCH_BACKEND=tavily to enable.
OPENAGENT_TAVILY_API_KEY=
OPENAGENT_TAVILY_BASE_URL=https://api.tavily.com

# Brave search backend
# Set OPENAGENT_WEBSEARCH_BACKEND=brave to enable.
OPENAGENT_BRAVE_API_KEY=
OPENAGENT_BRAVE_BASE_URL=https://api.search.brave.com

# Shared web-search tuning
OPENAGENT_WEBSEARCH_LIMIT=5

# Live smoke tests for web backends
OPENAGENT_RUN_FIRECRAWL_SMOKE=
OPENAGENT_RUN_TAVILY_SMOKE=
OPENAGENT_RUN_BRAVE_SMOKE=

# Real Feishu E2E
OPENAGENT_RUN_FEISHU_E2E=
OPENAGENT_RUN_FEISHU_GROUP_E2E=
OPENAGENT_FEISHU_E2E_P2P_CHAT_ID=
OPENAGENT_FEISHU_E2E_GROUP_ID=
OPENAGENT_FEISHU_E2E_BOT_NAME=openagent
OPENAGENT_FEISHU_E2E_LARK_CLI_BIN=lark-cli
OPENAGENT_FEISHU_E2E_P2P_SEND_TEMPLATE={binary} im +messages-send --as user --chat-id {chat_id} --text {text}
OPENAGENT_FEISHU_E2E_GROUP_SEND_TEMPLATE={binary} im +messages-send --as user --chat-id {chat_id} --text {text}
OPENAGENT_FEISHU_E2E_GROUP_MENTION_TEMPLATE={binary} im +messages-send --as user --chat-id {chat_id} --text {mention_text}

# Notes
# - OPENAGENT_SESSION_ROOT / OPENAGENT_BINDING_ROOT have channel-specific defaults when a channel-specific
#   assembly loads its own config:
#   - Feishu: .openagent/feishu/sessions and .openagent/feishu/sessions/bindings
#   - WeChat: .openagent/wechat/sessions and .openagent/wechat/sessions/bindings
#   - WeCom:  .openagent/wecom/sessions and .openagent/wecom/sessions/bindings
# - OPENAGENT_WORKSPACE_ROOT supports $PWD and ~ expansion.
